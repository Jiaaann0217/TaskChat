generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        Int      @id @default(autoincrement())
  name      String
  code      String   @unique
  createdAt DateTime @default(now())
  users     User[]
  rooms     Room[]
}

model User {
  id                 Int               @id @default(autoincrement())
  name               String            @unique
  password           String
  avatarColor        String            @default("#1C7293")
  createdAt          DateTime          @default(now())
  workspace          Workspace         @relation(fields: [workspaceId], references: [id])
  workspaceId        Int
  messages           Message[]
  tasks              Task[]
  logs               ContributionLog[]
  taskParticipations TaskParticipant[]

  @@unique([workspaceId, name])
}

model Room {
  id          Int       @id @default(autoincrement())
  name        String
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  workspaceId Int
  messages    Message[]
  pins        Pin[]
  tasks       Task[]
}

model Message {
  id           Int      @id @default(autoincrement())
  body         String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
  userId       Int
  room         Room     @relation(fields: [roomId], references: [id])
  roomId       Int
  pin          Pin?
  isRecruiting Boolean  @default(false)
  task         Task?
}

model Pin {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId Int      @unique
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    Int
}

model Task {
  id              Int               @id @default(autoincrement())
  title           String
  dueDate         DateTime?
  done            Boolean           @default(false)
  createdAt       DateTime          @default(now())
  assignedTo      User?             @relation(fields: [assignedToId], references: [id])
  assignedToId    Int?
  room            Room?             @relation(fields: [roomId], references: [id]) // ← 追加
  roomId          Int?
  sourceMessage   Message?          @relation(fields: [sourceMessageId], references: [id])
  sourceMessageId Int?              @unique // ← 追加：募集メッセージとの紐付け
  participants    TaskParticipant[] // ← 追加
}

model ContributionLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  roomId    Int // Roomへのリレーションは張らない（Room削除の影響を受けないようにするため）
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, roomId])
}

model TaskParticipant {
  id        Int      @id @default(autoincrement())
  task      Task     @relation(fields: [taskId], references: [id])
  taskId    Int
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  createdAt DateTime @default(now())

  @@unique([taskId, userId])
}
