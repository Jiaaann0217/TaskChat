generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  password  String
  avatarColor String            @default("#1C7293")
  createdAt DateTime  @default(now())
  messages  Message[]
  tasks     Task[]
  logs      ContributionLog[]
}

model Room {
  id        Int       @id @default(autoincrement())
  name      String
  createdAt DateTime  @default(now())
  messages  Message[]
  pins      Pin[]
  tasks     Task[]
}

model Message {
  id        Int      @id @default(autoincrement())
  body      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    Int
  pin       Pin?
  isRecruiting Boolean @default(false)
}

model Pin {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId Int      @unique
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    Int
}

model Task {
  id           Int       @id @default(autoincrement())
  title        String
  dueDate      DateTime?
  done         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  assignedTo   User?     @relation(fields: [assignedToId], references: [id])
  assignedToId Int?
  room         Room?     @relation(fields: [roomId], references: [id])  // ← 追加
  roomId       Int?
}

model ContributionLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  roomId    Int      // Roomへのリレーションは張らない（Room削除の影響を受けないようにするため）
  done      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, roomId])
}